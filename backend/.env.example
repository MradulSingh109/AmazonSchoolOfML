# QuantML Research Platform Environment Configuration Template

# Server mode: 'development' (auto-reloads backend on code change) or 'production' (multiprocess/worker deployment)
ENV=development

# Binding settings
HOST=127.0.0.1
PORT=5000
WORKERS=4

# Data directories (defaults to local /data/raw, /data/processed, /models inside backend)
# RAW_DIR=/path/to/raw_data
# PROCESSED_DIR=/path/to/processed_data
# MODELS_DIR=/path/to/models

# Logging configurations
LOG_DIR=logs
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - [%(levelname)s] - %(message)s
